APP_ENV=production
APP_DEBUG=false
APP_URL=https://example.com

DB_HOST=localhost
DB_PORT=3306
# Optional: use unix socket on some shared hosts
# DB_SOCKET=/var/lib/mysql/mysql.sock
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASS=your_db_pass
DB_CHARSET=utf8mb4

# Optional
SITE_LANG_DEFAULT=ar

# CSP reporting (safe rollout)
GDY_CSP_REPORT_ONLY=1
GDY_CSP_REPORT_URI=/csp-report.php
GDY_SECURITY_LOG=1

# --- Server-side PDF/TTS (requires exec tools on server) ---
GDY_ALLOW_EXEC=0
# For PDF: install wkhtmltopdf OR headless chrome
# For TTS: install espeak-ng/espeak (and ffmpeg or lame for MP3)
GDY_TTS_ENGINE=espeak
GDY_LOG_ENABLED=1
GDY_LOG_LEVEL=info


# Google Cloud Text-to-Speech (for TTS download on shared hosting)
GOOGLE_TTS_API_KEY=
# Optional: default language for TTS
GOOGLE_TTS_LANG=ar-XA
